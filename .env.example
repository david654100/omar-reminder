# Twilio credentials (from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio SMS-capable phone number (e.g. +16125551234)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Your personal phone number for SMS (e.g. +16125551234)
MY_PHONE_NUMBER=+1XXXXXXXXXX

# Gmail SMTP sender account (must be a Gmail address).
GMAIL_ADDRESS=you@gmail.com

# Gmail app password for the sender account (not your normal password).
GMAIL_APP_PASSWORD=your-16-char-app-password
GMAIL_IMAP_HOST=imap.gmail.com
EMAIL_REPLY_POLL_MINUTES=5

# Location for zmanim calculation (default: Minneapolis)
LATITUDE=44.9778
LONGITUDE=-93.2650
TIMEZONE=America/Chicago
LOCATION_NAME=Minneapolis

# Morning follow-up hour (24h format, local time)
MORNING_REMINDER_HOUR=8

# Flask secret key
SECRET_KEY=change-me-to-a-random-string

# Google OAuth (from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
ALLOWED_EMAIL=you@gmail.com

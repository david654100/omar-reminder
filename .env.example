# Twilio credentials (from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio WhatsApp number (e.g. whatsapp:+14155238886 for sandbox)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Your personal phone number (e.g. whatsapp:+16125551234)
MY_PHONE_NUMBER=whatsapp:+1XXXXXXXXXX

# Location for zmanim calculation (default: Minneapolis)
LATITUDE=44.9778
LONGITUDE=-93.2650
TIMEZONE=America/Chicago
LOCATION_NAME=Minneapolis

# Morning follow-up hour (24h format, local time)
MORNING_REMINDER_HOUR=8

# Flask secret key
SECRET_KEY=change-me-to-a-random-string

# Google OAuth (from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
ALLOWED_EMAIL=you@gmail.com
